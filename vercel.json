{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && BASE_PATH=/ pnpm --filter @workspace/nixx-ai run build",
  "outputDirectory": "artifacts/nixx-ai/dist/public",
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "framework": null,
  "functions": {
    "api/index.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
