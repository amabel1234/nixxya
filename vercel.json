{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/nixx-ai run build",
  "outputDirectory": "artifacts/nixx-ai/dist",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "toolbarConfig": {
    "enabled": false
  },
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
