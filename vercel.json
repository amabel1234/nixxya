{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-spec run codegen && pnpm --filter @workspace/nixx-ai run build && node api/build-vercel.mjs",
  "outputDirectory": "artifacts/nixx-ai/dist/public",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "build": {
    "env": {
      "PORT": "3000",
      "BASE_PATH": "/"
    }
  }
}
