{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-spec run codegen && pnpm --filter @workspace/nixx-ai run build",
  "outputDirectory": "artifacts/nixx-ai/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "PORT": "3000",
      "BASE_PATH": "/"
    }
  }
}