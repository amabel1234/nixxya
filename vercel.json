{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/nixx-ai run build",
  "outputDirectory": "artifacts/nixx-ai/dist",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}