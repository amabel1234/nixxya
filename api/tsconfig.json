{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "es2022"
    ],
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "./**/*.ts",
    "../artifacts/api-server/src/**/*.ts",
    "../lib/**/*.ts"
  ]
}